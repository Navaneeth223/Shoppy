# ============================================================
# NEXUS COMMERCE — SERVER ENVIRONMENT VARIABLES
# Copy this file to .env and fill in all values
# ============================================================

# Application
NODE_ENV=development
PORT=5000
API_VERSION=v1
FRONTEND_URL=http://localhost:5173
SELLER_DASHBOARD_URL=http://localhost:5174
ADMIN_DASHBOARD_URL=http://localhost:5175
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Database
MONGODB_URI=mongodb://localhost:27017/nexus_commerce
MONGODB_URI_PROD=mongodb+srv://user:password@cluster.mongodb.net/nexus_commerce

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT — Use strong random 256-bit secrets in production
JWT_ACCESS_SECRET=change_this_to_a_strong_random_256_bit_secret_for_access_tokens
JWT_REFRESH_SECRET=change_this_to_a_different_strong_random_256_bit_secret_for_refresh
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CONNECT_CLIENT_ID=ca_your_connect_client_id

# SendGrid — https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@nexuscommerce.com
EMAIL_FROM_NAME=Nexus Commerce

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# Facebook OAuth — https://developers.facebook.com/apps
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:5000/api/v1/auth/facebook/callback

# Business Rules
DEFAULT_COMMISSION_RATE=0.10
MINIMUM_PAYOUT_AMOUNT=50

# Feature Flags
ENABLE_2FA=true
ENABLE_SOCIAL_AUTH=true
ENABLE_GUEST_CHECKOUT=true
ENABLE_REVIEWS=true
ENABLE_WISHLIST=true
ENABLE_FLASH_DEALS=true
ENABLE_RECOMMENDATIONS=true

# Sentry (optional — error tracking)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id

# Session
SESSION_SECRET=change_this_to_a_strong_random_session_secret
